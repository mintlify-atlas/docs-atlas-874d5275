  "keyFeatures": [
    "Faster-than-realtime spacecraft 6-DOF dynamics simulation",
    "Modular architecture with message-passing interface (MPI) between simulation and FSW modules",
    "Python scripting interface over high-performance C/C++ core via SWIG",
    "Repeatable Monte-Carlo simulation engine with configurable distribution functions",
    "Hardware-in-the-loop (HIL) support with real-time synchronization",
    "Comprehensive FSW algorithm library: attitude control, GNC, orbit control, optical navigation",
    "Rich environment modeling: gravity, atmosphere, magnetic field, eclipse, space weather",
    "3D visualization companion app (Vizard) powered by Unity",
    "MuJoCo dynamics integration for advanced rigid body simulation",
    "Cross-platform: macOS, Linux, Windows; available via pip (bsk) and Docker"
  ],
  "publicApiSurface": [
    "SimulationBaseClass.SimBaseClass — base class for all BSK simulations",
    "SimulationBaseClass.Simulink_SimBase — realtime simulation base class",
    "messaging — message passing interface for module interconnection",
    "spacecraft — rigid body spacecraft dynamics module",
    "fswAlgorithms.attControl.mrpFeedback — MRP-based attitude feedback controller",
    "fswAlgorithms.attGuidance — attitude guidance modules",
    "fswAlgorithms.attDetermination — attitude determination algorithms",
    "fswAlgorithms.opticalNavigation — optical navigation filter modules",
    "simulation.dynamics — dynamics effectors (thrusters, RWs, hinged panels, etc.)",
    "simulation.environment — environment models (gravity, atmosphere, magnetic field)",
    "simulation.sensors — sensor models (CSS, IMU, star tracker, etc.)",
    "utilities.orbitalMotion — astrodynamics utility functions",
    "utilities.macros — unit conversion and simulation constants",
    "utilities.SimulationBaseClass — simulation setup utilities",
    "utilities.vizSupport — Vizard visualization integration",
    "utilities.MonteCarlo — Monte-Carlo simulation controller",
    "bskExamples (CLI) — downloads example scripts to local directory",
    "bskLargeData (CLI) — downloads large BSK support data files"
  ]
}
